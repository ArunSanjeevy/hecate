# DB_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Upstash TLS connection URL (copy the exact URL from the Upstash console)
REDIS_URL=rediss://default:<password>@<endpoint>.upstash.io:6379
